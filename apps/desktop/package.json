{
  "name": "chronicle-desktop",
  "version": "0.7.0",
  "description": "Chronicle — local-first version history for creative files, explained by AI",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "install-electron && electron-rebuild -f",
    "ensure-electron": "install-electron",
    "dev": "electron-vite dev",
    "prebuild": "npm run generate-api-types",
    "build": "electron-vite build",
    "build:sidecar": "python ../../scripts/build_ai_sidecar.py",
    "package": "npm run package:windows",
    "package:windows": "npm run build:sidecar && npm run build && electron-builder --win nsis --x64 --publish never",
    "package:mac": "npm run build:sidecar && npm run build && electron-builder --mac dmg --publish never",
    "package:unpacked": "npm run build:sidecar && npm run build && electron-builder --win --x64 --dir --publish never",
    "preview": "electron-vite preview",
    "test": "cross-env ELECTRON_RUN_AS_NODE=1 electron node_modules/vitest/vitest.mjs run",
    "test:mvp12": "python ../../scripts/mvp12_acceptance.py",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "generate-ai-types": "cd ../../services/ai && python -m chronicle_ai.export_openapi && cd ../../apps/desktop && openapi-typescript ../../packages/contracts/ai/openapi.json -o src/main/ai/generated.ts",
    "generate-api-types": "openapi-typescript ../../packages/contracts/api/openapi.json -o ../../packages/contracts/api/generated/index.ts"
  },
  "build": {
    "appId": "app.chronicle.desktop",
    "productName": "Chronicle",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../packages/brand/assets/png/chronicle-app-icon-dark-256.png",
        "to": "chronicle-app-icon.png"
      },
      {
        "from": "../../packages/prompts/version-annotation.md",
        "to": "ai/prompts/version-annotation.md"
      }
    ],
    "asar": true,
    "win": {
      "icon": "../../packages/brand/assets/chronicle-app-icon.ico",
      "extraResources": [
        {
          "from": "build/sidecar/chronicle-ai-sidecar.exe",
          "to": "ai/chronicle-ai-sidecar.exe"
        }
      ],
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "../../packages/brand/assets/png/chronicle-app-icon-dark-512.png",
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "extraResources": [
        {
          "from": "build/sidecar/chronicle-ai-sidecar",
          "to": "ai/chronicle-ai-sidecar"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "../../packages/brand/assets/chronicle-app-icon.ico",
      "uninstallerIcon": "../../packages/brand/assets/chronicle-app-icon.ico"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@material-symbols/svg-400": "^0.45.8",
    "@tailwindcss/vite": "4.3.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cross-env": "10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "openapi-typescript": "^7.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "4.3.3",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "chokidar": "5.0.0",
    "dotenv": "^17.2.3"
  }
}
