---
import { landingContent } from "../content";
import SeoHead from "./SeoHead.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  effectiveDate: string;
  currentPath: "/privacy" | "/terms-and-services";
}

const { title, description, eyebrow, effectiveDate, currentPath } = Astro.props;

const chronicleMarkSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="none"><path d="M38 12H19C11.8 12 8 16 8 22s3.8 10 11 10h12c5.5 0 8 2.7 8 7" stroke="#0f62fe" stroke-width="8" stroke-linecap="round"/><path d="M38 12H19c-4.4 0-7.5 1.5-9.2 4.2" stroke="#78a9ff" stroke-width="8" stroke-linecap="round"/><circle cx="38" cy="12" r="6" fill="#a6c8ff"/><circle cx="39" cy="39" r="5" fill="#78a9ff"/></svg>`;
const chronicleMarkUrl = `data:image/svg+xml,${encodeURIComponent(chronicleMarkSvg)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SeoHead
      title={`${title} | ${landingContent.productName}`}
      description={description}
      pathname={currentPath}
      pageType={currentPath === "/privacy" ? "privacy" : "terms"}
    />
    <title>{title} | {landingContent.productName}</title>
  </head>
  <body class="legal-body">
    <a class="skip-link" href="#legal-content">Skip to content</a>

    <header class="site-header legal-header" aria-label="Site header">
      <a class="brand" href="/" aria-label="Chronicle home">
        <img class="brand__icon" src={chronicleMarkUrl} alt="" width="26" height="26" />
        {landingContent.productName}
      </a>
      <nav class="legal-nav" aria-label="Legal navigation">
        <a href="/privacy" aria-current={currentPath === "/privacy" ? "page" : undefined}>Privacy</a>
        <a href="/terms-and-services" aria-current={currentPath === "/terms-and-services" ? "page" : undefined}>Terms</a>
      </nav>
      <a class="legal-back" href="/">Back to Chronicle</a>
    </header>

    <main id="legal-content" class="legal-shell">
      <header class="legal-hero">
        <p class="pill">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="legal-intro">{description}</p>
        <p class="legal-date">Effective {effectiveDate}</p>
      </header>

      <div class="legal-layout">
        <aside class="legal-aside" aria-label="On this page">
          <p>On this page</p>
          <nav><slot name="navigation" /></nav>
        </aside>
        <article class="legal-document"><slot /></article>
      </div>
    </main>

    <footer class="site-footer legal-footer">
      <span>Chronicle · Local-first creative version control</span>
      <nav aria-label="Footer navigation">
        <a href="/privacy">Privacy</a>
        <a href="/terms-and-services">Terms of Service</a>
        <a href={landingContent.githubUrl}>GitHub</a>
      </nav>
    </footer>
  </body>
</html>
