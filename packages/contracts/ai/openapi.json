{
  "openapi": "3.1.0",
  "info": {
    "title": "Chronicle Local AI Service",
    "description": "Loopback-only annotation and text-embedding service.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Report process health without contacting an external provider.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/annotate": {
      "post": {
        "summary": "Annotate",
        "operationId": "annotate_annotate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnnotateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionAnnotation"
                }
              }
            }
          },
          "502": {
            "description": "Provider or model output error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Provider integration unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Provider timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/embed-text": {
      "post": {
        "summary": "Create Text Embedding",
        "operationId": "create_text_embedding_embed_text_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmbedTextRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbedTextResponse"
                }
              }
            }
          },
          "502": {
            "description": "Provider or model output error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Provider integration unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Provider timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnnotateRequest": {
        "properties": {
          "provider": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Model"
          },
          "apiKey": {
            "type": "string",
            "format": "password",
            "title": "Apikey",
            "writeOnly": true
          },
          "fileName": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Filename"
          },
          "previous": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ImageInput"
              },
              {
                "type": "null"
              }
            ]
          },
          "current": {
            "$ref": "#/components/schemas/ImageInput"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "provider",
          "model",
          "apiKey",
          "fileName",
          "current"
        ],
        "title": "AnnotateRequest"
      },
      "EmbedTextRequest": {
        "properties": {
          "provider": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Model"
          },
          "apiKey": {
            "type": "string",
            "format": "password",
            "title": "Apikey",
            "writeOnly": true
          },
          "text": {
            "type": "string",
            "maxLength": 10000,
            "minLength": 1,
            "title": "Text"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "provider",
          "model",
          "apiKey",
          "text"
        ],
        "title": "EmbedTextRequest"
      },
      "EmbedTextResponse": {
        "properties": {
          "embedding": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "minItems": 1,
            "title": "Embedding"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "dimensions": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Dimensions"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "embedding",
          "provider",
          "model",
          "dimensions"
        ],
        "title": "EmbedTextResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "const": "ok",
            "title": "Status",
            "default": "ok"
          },
          "service": {
            "type": "string",
            "const": "chronicle-ai",
            "title": "Service",
            "default": "chronicle-ai"
          },
          "version": {
            "type": "string",
            "title": "Version",
            "default": "0.1.0"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "HealthResponse"
      },
      "ImageInput": {
        "properties": {
          "base64": {
            "type": "string",
            "minLength": 1,
            "title": "Base64"
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "image/png",
              "image/jpeg"
            ],
            "title": "Mediatype"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "base64",
          "mediaType"
        ],
        "title": "ImageInput",
        "description": "One PNG or JPEG transported across the local HTTP boundary."
      },
      "ServiceErrorDetail": {
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "invalid_model_output",
              "provider_unavailable",
              "provider_timeout",
              "provider_error"
            ],
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ServiceErrorDetail"
      },
      "ServiceErrorResponse": {
        "properties": {
          "detail": {
            "$ref": "#/components/schemas/ServiceErrorDetail"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ServiceErrorResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VersionAnnotation": {
        "properties": {
          "summary": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Summary"
          },
          "changes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 6,
            "minItems": 1,
            "title": "Changes"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 8,
            "minItems": 3,
            "title": "Tags"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "summary",
          "changes",
          "tags"
        ],
        "title": "VersionAnnotation",
        "description": "Exact C3 annotation output shared with the Electron app."
      }
    }
  }
}
