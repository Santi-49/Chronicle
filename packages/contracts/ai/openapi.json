{
  "openapi": "3.1.0",
  "info": {
    "title": "Chronicle Local AI Service",
    "description": "Loopback-only annotation and text-embedding service.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Report process health without contacting an external provider.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/annotate": {
      "post": {
        "summary": "Annotate",
        "operationId": "annotate_annotate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnnotateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnnotateResponse"
                }
              }
            }
          },
          "400": {
            "description": "No provider/model/key configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Provider rejected the credential",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Provider rejected the request size",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Provider quota or rate limit reached",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Provider or model output error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Provider integration unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Provider timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/embed-text": {
      "post": {
        "summary": "Create Text Embedding",
        "operationId": "create_text_embedding_embed_text_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmbedTextRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbedTextResponse"
                }
              }
            }
          },
          "400": {
            "description": "No provider/model/key configured",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Provider rejected the credential",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Provider rejected the request size",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Provider quota or rate limit reached",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Provider or model output error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Provider integration unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "504": {
            "description": "Provider timeout",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServiceErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/validate-provider-model": {
      "post": {
        "summary": "Validate Configuration",
        "description": "Probe a provider/model/key with the real operation used by its task.",
        "operationId": "validate_configuration_validate_provider_model_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateProviderModelRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateProviderModelResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnnotateRequest": {
        "properties": {
          "provider": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 50,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Provider"
          },
          "model": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          },
          "apiKey": {
            "anyOf": [
              {
                "type": "string",
                "format": "password",
                "writeOnly": true
              },
              {
                "type": "null"
              }
            ],
            "title": "Apikey"
          },
          "fileName": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Filename"
          },
          "previous": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ImageInput"
              },
              {
                "type": "null"
              }
            ]
          },
          "current": {
            "$ref": "#/components/schemas/ImageInput"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "fileName",
          "current"
        ],
        "title": "AnnotateRequest"
      },
      "AnnotateResponse": {
        "properties": {
          "summary": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Summary"
          },
          "changes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 6,
            "minItems": 1,
            "title": "Changes"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 8,
            "minItems": 3,
            "title": "Tags"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 1.0,
                "minimum": 0.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          },
          "usage": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TokenUsage"
              },
              {
                "type": "null"
              }
            ]
          },
          "cost": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CostEstimate"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "summary",
          "changes",
          "tags"
        ],
        "title": "AnnotateResponse",
        "description": "C3 annotation plus token usage and the estimated cost of the call."
      },
      "CostEstimate": {
        "properties": {
          "input_usd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Input Usd"
          },
          "output_usd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output Usd"
          },
          "total_usd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Usd"
          },
          "currency": {
            "type": "string",
            "const": "USD",
            "title": "Currency",
            "default": "USD"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "CostEstimate",
        "description": "Estimated USD cost of one call from token usage × configured prices."
      },
      "EmbedTextRequest": {
        "properties": {
          "provider": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 50,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Provider"
          },
          "model": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 200,
                "minLength": 1
              },
              {
                "type": "null"
              }
            ],
            "title": "Model"
          },
          "apiKey": {
            "anyOf": [
              {
                "type": "string",
                "format": "password",
                "writeOnly": true
              },
              {
                "type": "null"
              }
            ],
            "title": "Apikey"
          },
          "text": {
            "type": "string",
            "maxLength": 10000,
            "minLength": 1,
            "title": "Text"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "text"
        ],
        "title": "EmbedTextRequest"
      },
      "EmbedTextResponse": {
        "properties": {
          "embedding": {
            "items": {
              "type": "number"
            },
            "type": "array",
            "minItems": 1,
            "title": "Embedding"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "dimensions": {
            "type": "integer",
            "exclusiveMinimum": 0.0,
            "title": "Dimensions"
          },
          "usage": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TokenUsage"
              },
              {
                "type": "null"
              }
            ]
          },
          "cost": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CostEstimate"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "embedding",
          "provider",
          "model",
          "dimensions"
        ],
        "title": "EmbedTextResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "const": "ok",
            "title": "Status",
            "default": "ok"
          },
          "service": {
            "type": "string",
            "const": "chronicle-ai",
            "title": "Service",
            "default": "chronicle-ai"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "version"
        ],
        "title": "HealthResponse"
      },
      "ImageInput": {
        "properties": {
          "base64": {
            "type": "string",
            "minLength": 1,
            "title": "Base64"
          },
          "mediaType": {
            "type": "string",
            "enum": [
              "image/png",
              "image/jpeg"
            ],
            "title": "Mediatype"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "base64",
          "mediaType"
        ],
        "title": "ImageInput",
        "description": "One PNG or JPEG transported across the local HTTP boundary."
      },
      "ServiceErrorDetail": {
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "configuration_error",
              "invalid_model_output",
              "provider_unavailable",
              "provider_timeout",
              "provider_error"
            ],
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ServiceErrorDetail"
      },
      "ServiceErrorResponse": {
        "properties": {
          "detail": {
            "$ref": "#/components/schemas/ServiceErrorDetail"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ServiceErrorResponse"
      },
      "TokenUsage": {
        "properties": {
          "input_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Input Tokens"
          },
          "output_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output Tokens"
          },
          "total_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Tokens"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "TokenUsage",
        "description": "Token counts reported by the provider for one call (null when absent)."
      },
      "ValidateProviderModelRequest": {
        "properties": {
          "task": {
            "type": "string",
            "enum": [
              "chat",
              "embeddings"
            ],
            "title": "Task"
          },
          "provider": {
            "type": "string",
            "maxLength": 50,
            "minLength": 1,
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "maxLength": 200,
            "minLength": 1,
            "title": "Model"
          },
          "apiKey": {
            "type": "string",
            "format": "password",
            "title": "Apikey",
            "writeOnly": true
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "task",
          "provider",
          "model",
          "apiKey"
        ],
        "title": "ValidateProviderModelRequest",
        "description": "A fully specified task configuration to probe against its provider."
      },
      "ValidateProviderModelResponse": {
        "properties": {
          "valid": {
            "type": "boolean",
            "title": "Valid"
          },
          "reachable": {
            "type": "boolean",
            "title": "Reachable"
          },
          "task": {
            "type": "string",
            "enum": [
              "chat",
              "embeddings"
            ],
            "title": "Task"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "valid",
          "reachable",
          "task",
          "provider",
          "model",
          "message"
        ],
        "title": "ValidateProviderModelResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
