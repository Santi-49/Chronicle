# ── Postgres ──────────────────────────────────────────────────────────
POSTGRES_DB=hackathon
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://hackathon:changeme@postgres:5432/hackathon

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OPA ───────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-at-least-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Chronicle AI service (services/ai) ────────────────────────────────
# Model-agnostic defaults for the local AI service. The desktop app sends
# provider/model/key per request (BYOK); these values are the fallback used by
# the standalone service (make run-ai), the smoke script, and the live test.
# Copy this file to .env and set your real key. The .env file is git-ignored;
# never commit a real key.
CHRONICLE_AI_PROVIDER=google_genai
CHRONICLE_AI_API_KEY=your_actual_api_key_here

# Per-task models — different models per task are supported.
CHRONICLE_AI_ANNOTATE_MODEL=gemini-flash-latest
CHRONICLE_AI_EMBED_MODEL=gemini-embedding-001

# Per-task pricing — USD per 1,000,000 tokens — used for the cost estimate
# returned by the API and shown in tests. EXAMPLE VALUES ONLY: replace with your
# provider's current pricing. Embeddings are billed on input tokens only.
CHRONICLE_AI_ANNOTATE_INPUT_PRICE_PER_M=0.075
CHRONICLE_AI_ANNOTATE_OUTPUT_PRICE_PER_M=0.30
CHRONICLE_AI_EMBED_INPUT_PRICE_PER_M=0.15