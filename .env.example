# ── Postgres ──────────────────────────────────────────────────────────
POSTGRES_DB=hackathon
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://hackathon:changeme@postgres:5432/hackathon

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OPA ───────────────────────────────────────────────────────────────
OPA_URL=http://opa:8181

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-at-least-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=changeme
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Google sign-in (POST-03) ──────────────────────────────────────────
# Public origin of the Chronicle control-plane API. Do not include /api/v1;
# Electron also calls the root /health endpoint before enabling Google sign-in.
CHRONICLE_CONTROL_PLANE_URL=http://localhost:8000

# Create an OAuth 2.0 client of type "Desktop app" in Google Auth Platform.
# The client ID is public and is used by Electron and the API (audience check).
GOOGLE_OAUTH_CLIENT_ID=your-desktop-client-id.apps.googleusercontent.com
# Desktop OAuth clients cannot keep secrets. Chronicle's PKCE flow does not use
# this value; it is documented only because Google may include it in downloaded
# credentials. Never bundle it into Electron or commit a real value.
GOOGLE_OAUTH_CLIENT_SECRET=unused-for-desktop-pkce

# ── Chronicle AI service (services/ai) ────────────────────────────────
# Model-agnostic defaults for the local AI service. The desktop app sends
# provider/model/key per request (BYOK) and stores one key PER PROVIDER in the
# OS keychain (Electron safeStorage) — so switching a task's provider never
# needs re-entry. These env vars are only the fallback used by the STANDALONE
# service (make run-ai), the smoke script, and the live test.
# Copy this file to .env and set your real key. The .env file is git-ignored;
# never commit a real key.
CHRONICLE_AI_PROVIDER=google_genai
CHRONICLE_AI_API_KEY=your_actual_api_key_here

# Multiple providers: the desktop app manages a separate key per provider in the
# OS keychain, so no .env entry is needed for it. For the standalone service you
# select one provider via CHRONICLE_AI_PROVIDER above; LangChain also reads these
# provider-native variables when a matching provider/model is used. Uncomment the
# ones you need — set only real keys and never commit them.
# GOOGLE_API_KEY=your_google_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# Amazon Bedrock uses standard AWS credentials rather than a single API key:
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1

# Per-task models — different models per task are supported.
CHRONICLE_AI_ANNOTATE_MODEL=gemini-flash-latest
CHRONICLE_AI_EMBED_MODEL=gemini-embedding-001

# Per-task pricing — USD per 1,000,000 tokens — used for the cost estimate
# returned by the API and shown in tests. EXAMPLE VALUES ONLY: replace with your
# provider's current pricing. Embeddings are billed on input tokens only.
CHRONICLE_AI_ANNOTATE_INPUT_PRICE_PER_M=0.075
CHRONICLE_AI_ANNOTATE_OUTPUT_PRICE_PER_M=0.30
CHRONICLE_AI_EMBED_INPUT_PRICE_PER_M=0.15
